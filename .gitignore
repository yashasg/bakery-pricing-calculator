# macOS system file
.DS_Store

# Xcode
*.xcuserstate
xcuserdata/

# Xcode local derived data
app/.build/
.build/

# Fastlane artifacts
app/fastlane/*.ipa
app/fastlane/*.xcarchive
app/fastlane/asc_api_key.json
app/.build/gym/

# Gems (keep Gemfile.lock in version control)
.bundle/

# Squad: ignore runtime state (logs, inbox, sessions, health reports)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/health-report.txt

# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Excalidraw MCP server runtime log
excalidraw.log
